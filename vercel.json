{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": { "api/**/*.js": { "maxDuration": 60 } },
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }],
  "crons": [
    { "path": "/api/fortnox-sync", "schedule": "0 21 * * *" },
    { "path": "/api/fortnox-sync", "schedule": "0 22 * * *" }
  ]
}
